# ─────────────────────────────────────────────────────────────────────────────
# config.env — Local development configuration
#
# Load before running:
#   export $(grep -v '^#' config.env | xargs)
#   mvn spring-boot:run
#
# In Kubernetes:
#   Non-sensitive values  →  ConfigMap
#   Sensitive values      →  Secret  (marked with [SECRET] below)
# ─────────────────────────────────────────────────────────────────────────────

# ── App identity — ConfigMap ──────────────────────────────────────────────────
APP_NAME=StockRoom
APP_ENV=development
APP_VERSION=1.0.0

# ── Server — ConfigMap ───────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database — ConfigMap (host/port/name are not sensitive) ──────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockroom

# ── Database credentials — [SECRET] ──────────────────────────────────────────
DB_USERNAME=stockroom_user
DB_PASSWORD=stockroom_pass

# ── File upload — ConfigMap ───────────────────────────────────────────────────
UPLOAD_PATH=/tmp/stockroom/uploads
MAX_FILE_SIZE_MB=10

# ── JWT — ConfigMap (expiry), Secret (signing key) ────────────────────────────
JWT_EXPIRY_HOURS=24
# [SECRET] — must be at least 32 characters in production
JWT_SECRET=local-dev-secret-key-please-change-this

# ── Exchange Rate API — ConfigMap (URL + TTL), Secret (key) ──────────────────
EXCHANGE_API_URL=https://v6.exchangerate-api.com/v6
EXCHANGE_CACHE_TTL_SECONDS=60
EXCHANGE_DEFAULT_BASE=USD
# [SECRET] — leave empty to use mock rates (no signup needed)
EXCHANGE_API_KEY=

# ── Pagination — ConfigMap ────────────────────────────────────────────────────
PAGINATION_DEFAULT_SIZE=12

# ── Logging — ConfigMap ───────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Seed data — [SECRET] ─────────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=admin123
